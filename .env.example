# --- Database ---
# Any SQLAlchemy-compatible URL, e.g.:
# postgresql+psycopg2://user:password@host:5432/dbname
# mysql+pymysql://user:password@host:3306/dbname
# sqlite:///local.db
#
# This matches the same example Postgres DB used in the original GW repo
# (see docker-compose.yml to spin up a local instance with these creds).
# Published on port 5433 (not 5432) to avoid clashing with any other local
# Postgres instance you may already have running (e.g. a separate GW checkout).
DATABASE_URL=postgresql+psycopg2://export_user:export_pass@localhost:5433/export_db

# --- SFTP delivery ---
# Pre-filled for the local test SFTP server started by `docker compose up -d`
# (docker-compose.yml's "sftp" service, atmoz/sftp). Point these at a real
# server instead when you're ready — swap SFTP_HOST/PORT/credentials below.
SFTP_HOST=localhost
SFTP_PORT=2222
SFTP_USERNAME=sftp_user
# Use EITHER a password OR a private key path (key takes priority if set)
SFTP_PASSWORD=sftp_pass
SFTP_PRIVATE_KEY_PATH=
# Remote directory exported files get uploaded into
SFTP_REMOTE_DIR=/incoming

# --- Email delivery ---
# Used by exports with `delivery: email` in definitions.yaml (sent as an
# attachment via SMTP to each address in that export's email_to list).
#
# Option A: local test SMTP server started by `docker compose up -d`
# (docker-compose.yml's "mailhog" service) — sent mail is caught, never
# actually delivered, and viewable at http://localhost:8025. Good for
# development; nothing lands in a real inbox.
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_USERNAME=
#   SMTP_PASSWORD=
#   SMTP_USE_TLS=false
#
# Option B: real delivery via Gmail SMTP. SMTP_USERNAME must be a full
# @gmail.com address; SMTP_PASSWORD must be a 16-character Google App
# Password (NOT your regular Gmail password) — generate one at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification
# enabled on the account first).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_address@gmail.com
SMTP_PASSWORD=REPLACE_WITH_16_CHAR_APP_PASSWORD
# true/false — STARTTLS after connecting (required by Gmail; MailHog doesn't support it)
SMTP_USE_TLS=true
# From: address on outgoing export emails. Defaults to SMTP_USERNAME if unset.
EMAIL_FROM=your_address@gmail.com

# Local scratch folder where files are written before upload
LOCAL_OUTPUT_DIR=./output

# --- Logging / tracking ---
# Every log line is written to console + logs/export.log + the log_events
# table in DATABASE_URL. Every run is also written to export_logs as a
# one-row-per-run summary. Both ported from the tracking part of the GW repo.
LOG_LEVEL=INFO
LOG_DIR=./logs
